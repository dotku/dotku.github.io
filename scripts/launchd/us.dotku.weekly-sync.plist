<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>us.dotku.weekly-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>python3</string>
        <string>/Users/wlin/dev/dotku.github.io/scripts/weekly-sync.py</string>
    </array>

    <!-- Every Sunday at 05:00 local time -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>0</integer>
        <key>Hour</key>
        <integer>5</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Don't run at load time; only on schedule. If a scheduled run is missed
         (laptop asleep), launchd runs it as soon as the machine is awake. -->
    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/wlin/dev/dotku.github.io/scripts/logs/weekly-sync.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/wlin/dev/dotku.github.io/scripts/logs/weekly-sync.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- PATH needs to include nvm node for `claude` + Homebrew for `gh`, `git` -->
        <key>PATH</key>
        <string>/Users/wlin/.nvm/versions/node/v20.17.0/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/wlin</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/wlin/dev/dotku.github.io</string>

    <!-- Don't restart on failure; we'll catch it in the next week's run -->
    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
